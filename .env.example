# ============================================================
# LOCAL DEVELOPMENT (.env)
# ============================================================

# Backend
JWT_SECRET=replace-with-strong-random-secret
MONGODB_URI=mongodb://localhost:27017/try
PORT=4000
NODE_ENV=development

# CORS: who is allowed to call the backend
# Local dev  → http://localhost:4200
# Production → your Netlify URL
CORS_ORIGIN=http://localhost:4200

# Ollama (AI assistant)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Frontend: where the Angular app calls the backend
# Local dev  → http://localhost:4000
# Production → your Render URL
API_URL=http://localhost:4000
DEBUG=true

# ============================================================
# PRODUCTION VALUES (set in Render + Netlify dashboards)
# ============================================================
# Render env vars:
#   JWT_SECRET   → auto-generated by render.yaml
#   MONGODB_URI  → your MongoDB Atlas connection string
#   CORS_ORIGIN  → https://your-app.netlify.app   ← Netlify URL
#   NODE_ENV     → production
#
# Netlify env vars:
#   API_URL      → https://your-app.onrender.com  ← Render URL
#   DEBUG        → false

# ============================================================
# DOCKER / VPS DEPLOYMENT (optional)
# ============================================================
DOMAIN=yourdomain.com
ACME_EMAIL=you@yourdomain.com

# Seed script (first-time setup only)
SEED_ADMIN_USER=admin
SEED_ADMIN_PASS=replace-with-strong-password
SEED_ADMIN_GROUP=A
